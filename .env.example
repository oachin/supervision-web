# === Havet Supervision - Configuration ===
# Copier vers .env : cp .env.example .env

# --- Production ---
DOMAIN=supervision-web-01.havetdigital.app
CERTBOT_EMAIL=admin@havetdigital.app

# Base de données (volume Docker persistant : postgres_data)
POSTGRES_USER=supervision
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=supervision

# Redis (volume Docker persistant : redis_data)
REDIS_PASSWORD=change_me_redis_password

# Sécurité (générer avec: bash scripts/generate-secrets.sh)
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=
AGENT_API_KEY_SALT=

# Compte admin initial (créé au premier démarrage)
# Astuce : mettez les mots de passe entre guillemets simples si ils contiennent $ ou !
ADMIN_EMAIL=admin@havetdigital.app
ADMIN_PASSWORD='change_me_admin_password'

# URLs production (HTTPS via Nginx)
CORS_ORIGIN=https://supervision-web-01.havetdigital.app
NEXT_PUBLIC_API_URL=https://supervision-web-01.havetdigital.app

# Ports (production : seuls 80/443 exposés via Nginx)
HTTP_PORT=80
HTTPS_PORT=443

# --- Développement local (docker compose up sans .prod.yml) ---
# FRONTEND_PORT=3000
# BACKEND_PORT=4000
# CORS_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000
