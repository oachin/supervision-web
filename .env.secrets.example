# === Havet Supervision — Secrets ===
# Copier vers .env.secrets : cp .env.secrets.example .env.secrets
# Ne JAMAIS commiter ce fichier. Pas de guillemets nécessaires si pas de $ dans les valeurs.

POSTGRES_USER=supervision
POSTGRES_PASSWORD=
POSTGRES_DB=supervision

REDIS_PASSWORD=

JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=
AGENT_API_KEY_SALT=

ADMIN_EMAIL=admin@havetdigital.app
ADMIN_PASSWORD=

# URLs complètes (évite l'interpolation $ dans docker-compose)
DATABASE_URL=postgresql://supervision:MOT_DE_PASSE_POSTGRES@postgres:5432/supervision
REDIS_URL=redis://:MOT_DE_PASSE_REDIS@redis:6379
